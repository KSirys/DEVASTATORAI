# DevastatorAI Environment Configuration
# Copy this file to .env and fill in your values.
# start.bat / start.sh will do this automatically on first run.

# ---------------------------------------------------------------------------
# LLM Backend
# ---------------------------------------------------------------------------

# URL of your local Ollama instance.
# Default works for a standard Ollama install on the same machine.
OLLAMA_URL=http://localhost:11434

# OpenRouter API key. Leave blank to use Ollama (local, free).
# Set this to route requests through OpenRouter's cloud models instead.
# Get a key: https://openrouter.ai/
OPENROUTER_API_KEY=

# Default model to use when the agent config says "${DEFAULT_MODEL}".
# For Ollama:      any model you've pulled locally, e.g. qwen2.5:7b, llama3.1:8b
# For OpenRouter:  model path like openai/gpt-4o, anthropic/claude-3-haiku, etc.
DEFAULT_MODEL=qwen2.5:7b

# ---------------------------------------------------------------------------
# Operation Mode
# ---------------------------------------------------------------------------

# Controls how Chief routes tasks and how many agents are involved.
#
#   solo     — one agent handles the full request, local Ollama only
#              fastest, free, works completely offline
#
#   team     — Chief classifies the task and routes to 1-3 agents sequentially
#              uses OpenRouter free tier if OPENROUTER_API_KEY is set, else Ollama
#
#   fullops  — all relevant agents run in parallel using the best available models
#              estimates cost before running and asks for confirmation
#              requires OPENROUTER_API_KEY for best results
#
OPERATION_MODE=solo

# ---------------------------------------------------------------------------
# Web Search Provider
# ---------------------------------------------------------------------------

# Provider to use for web search (used by Rachel and other research tasks).
#
#   duckduckgo  (default) — free, no key required, works out of the box
#   google                — more accurate, requires GOOGLE_API_KEY + GOOGLE_CSE_ID
#   brave                 — privacy-focused, requires BRAVE_API_KEY
#
SEARCH_PROVIDER=duckduckgo

# Google Custom Search (only needed if SEARCH_PROVIDER=google)
# API key:  https://developers.google.com/custom-search/v1/overview
# CSE ID:   https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Brave Search API (only needed if SEARCH_PROVIDER=brave)
# Free tier: 2,000 queries/month
# Get key:   https://api.search.brave.com/
BRAVE_API_KEY=

# Serper.dev API (reserved for future integration)
# Get key:   https://serper.dev/
SERPER_API_KEY=
